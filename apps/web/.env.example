# ─── Magic (embedded wallet auth) ──────────────────────────────────────────────
# Get these from https://dashboard.magic.link → your app → API Keys

NEXT_PUBLIC_MAGIC_PUBLISHABLE_KEY=pk_live_your-magic-publishable-key
MAGIC_SECRET_KEY=sk_live_your-magic-secret-key

# ─── Postgres (matches docker-compose.yml defaults) ───────────────────────────
DATABASE_URL=postgresql://plugix:plugix@localhost:5433/plugix

# ─── Arbitrum settlement ───────────────────────────────────────────────────────
ARBITRUM_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc
NEXT_PUBLIC_ARBITRUM_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc
ARBITRUM_USDC_ADDRESS=0x75faf114eafb1BDbe2F0316DF893fd58CE46AA4d

# Fallback shared payer wallet, used for unauthenticated /api/mcp calls
# (no Openfort agent wallet to attribute the payment to).
PAYER_PRIVATE_KEY=

# ─── Particle Universal Accounts (EIP-7702) ────────────────────────────────────
# Get these from https://dashboard.particle.network — optional: the app runs
# in demo mode with a fixed mock balance when unset.
NEXT_PUBLIC_PARTICLE_PROJECT_ID=
NEXT_PUBLIC_PARTICLE_CLIENT_KEY=
NEXT_PUBLIC_PARTICLE_APP_ID=
PARTICLE_PROJECT_ID=
PARTICLE_CLIENT_KEY=
PARTICLE_APP_ID=

# ─── Openfort (agent wallets + x402) ───────────────────────────────────────────
# Get this from https://dashboard.openfort.io — optional: falls back to a
# simulated agent wallet + fake tx hashes when unset.
OPENFORT_SECRET_KEY=

# ─── Optional ────────────────────────────────────────────────────────────────
# Address that receives platform fees on-chain.
# PLATFORM_RECEIVER_ADDRESS=0x...
