# =============================================================================
# Axon — apps/web env (Particle Auth + UA + Openfort)
# =============================================================================
# Copy to: apps/web/.env.local
# =============================================================================

DATABASE_URL=postgresql://plugix:plugix@localhost:5433/plugix

# ─── Particle Auth + Universal Accounts (REQUIRED) ───────────────────────────
# dashboard.particle.network → Project ID, Client Key, Web App ID, Server Key
NEXT_PUBLIC_PARTICLE_PROJECT_ID=
NEXT_PUBLIC_PARTICLE_CLIENT_KEY=
NEXT_PUBLIC_PARTICLE_APP_ID=
PARTICLE_PROJECT_ID=
PARTICLE_CLIENT_KEY=
PARTICLE_APP_ID=
PARTICLE_SERVER_KEY=

# ─── Arbitrum Sepolia ────────────────────────────────────────────────────────
ARBITRUM_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc
NEXT_PUBLIC_ARBITRUM_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc
ARBITRUM_USDC_ADDRESS=0x75faf114eafb1BDbe2F0316DF893fd58CE46AA4d

# ─── Openfort agent wallets (REQUIRED for MCP payments) ──────────────────────
# Wallet secret must be base64 DER (EC P-256), NOT a PEM block.
# dashboard.openfort.io → Developers → Wallet secret (copy as-is)
OPENFORT_SECRET_KEY=
OPENFORT_WALLET_SECRET=
OPENFORT_POLICY_ID=

NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
