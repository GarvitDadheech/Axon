# =============================================================================
# Axon — apps/api env (Express paid demo tools on :4000)
# =============================================================================
#
# WHERE THIS GOES
# ---------------
# Prefer: put these in the REPO ROOT `.env`
#   apps/api's `npm run dev` runs:  dotenv -e ../../.env -- tsx ...
# So `apps/api/.env` is NOT loaded unless you change the script.
#
# This file is documentation / a checklist for the API process only.
# packages/sdk reads nothing from disk — usdcPaywall(receiver, rpcUrl, …) args.
# =============================================================================


# ─── Required ────────────────────────────────────────────────────────────────
ARBITRUM_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc
# Wallet that receives USDC from x402 payments
RECEIVER_ADDRESS=0xYOUR_RECEIVER_WALLET_ADDRESS_HERE


# ─── Optional ────────────────────────────────────────────────────────────────
PORT=4000
# Native USDC on Arbitrum Sepolia (defaults inside @x402/payment-middleware if unset)
TOKEN_ADDRESS=0x75faf114eafb1BDbe2F0316DF893fd58CE46AA4d


# ─── Optional — real image / video responses ─────────────────────────────────
# Prefer AZURE_SORA_ENDPOINT + AZURE_API_KEY. AZURE_OPENAI_* also works as fallback.
AZURE_SORA_ENDPOINT=https://your-resource.openai.azure.com
AZURE_API_KEY=
AZURE_IMAGE_DEPLOYMENT=gpt-image-2
AZURE_VIDEO_MODEL=sora-2
# AZURE_OPENAI_ENDPOINT=
# AZURE_OPENAI_API_KEY=
