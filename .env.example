# Root env (used by both apps)

# Arbitrum Configuration
ARBITRUM_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc
RECEIVER_ADDRESS=0xYOUR_RECEIVER_WALLET_ADDRESS_HERE
PORT=4000
TOKEN_ADDRESS=0x75faf114eafb1BDbe2F0316DF893fd58CE46AA4d  # USDC on Arbitrum Sepolia

# Web App
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
PAYER_PRIVATE_KEY=0xYOUR_PAYER_PRIVATE_KEY_HERE  # fallback shared payer wallet (unauthenticated MCP calls)

# Azure OpenAI (for AI endpoint)
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_API_KEY=your_api_key_here
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_API_VERSION=2024-02-15-preview
